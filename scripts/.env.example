# SMTP 邮件配置 — QQ邮箱
# 复制此文件为 .env 并填入真实值
# .env 文件不会被 git 提交

# === 必填 ===

# QQ邮箱地址（也是发件人）
SMTP_USER=your_qq_email@qq.com

# QQ邮箱 SMTP 授权码（非登录密码！）
# 获取方式：QQ邮箱 → 设置 → 账户 → POP3/IMAP/SMTP → 开启 → 生成授权码
SMTP_PASS=your_authorization_code_here

# 接收报告的邮箱地址（可以和发件人相同）
SMTP_TO=recipient@example.com

# === 以下通常不需要修改 ===

SMTP_HOST=smtp.qq.com
SMTP_PORT=465
SMTP_USE_SSL=true

# 发件人地址（默认等于 SMTP_USER，一般不需要改）
# SMTP_FROM=your_qq_email@qq.com
